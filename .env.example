# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AI (optional — app works without, uses template fallbacks)
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxx

# Email (IMAP) — for parsing Airbnb/VRBO notification emails
# Works with Yahoo, Gmail, Outlook, iCloud, Fastmail, etc.
# Yahoo setup: generate an app password at https://login.yahoo.com/account/security
IMAP_HOST=imap.mail.yahoo.com
IMAP_PORT=993
IMAP_USER=your-email@yahoo.com
IMAP_PASSWORD=your-yahoo-app-password

# Telegram Bot (for receiving draft notifications)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz
TELEGRAM_CHAT_ID=123456789

